{
  "name": "depends",
  "version": "1.0.0",
  "description": "Reactive frontmatter dependency links for Obsidian.",
  "author": "Aru Gyani",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "lint": "eslint src/"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "dependencies",
    "graph"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/parser": "^8.59.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.8",
    "obsidian": "^1.5.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
